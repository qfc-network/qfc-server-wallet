# Rust
/target/
# Any nested target directories (workspace excludes / standalone clients).
**/target/
# The enclave/ Cargo project is a separate workspace and has its own
# target directory; exclude it too. (Generic `target/` rule would also
# work but the explicit form documents intent.)
enclave/target/
**/*.rs.bk
*.pdb

# Workspace lock — we DO commit Cargo.lock at the workspace root for
# reproducible binary builds; the line below is intentionally absent.
# (Library crates without their own lockfile inherit from the workspace.)

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# direnv
.envrc
.direnv/

# Enclave build artifacts (M3+)
enclave/build/
# Note: `Dockerfile.eif` is the build recipe and IS committed; only the
# build outputs are ignored.
enclave/build/*.eif
enclave/build/*.pcr
*.eif.out
*.pcr.out

# Local policy overrides (operators occasionally drop *.local.json files for testing)
examples/policies/*.local.json
policies/*.local.json

# Coverage / profiling
*.profraw
*.profdata
tarpaulin-report.html
cobertura.xml
lcov.info

# Cargo
**/Cargo.lock.bak

# Node (clients/approver-ts/)
node_modules/
clients/approver-ts/dist/
clients/approver-ts/coverage/

# Secrets — defensive only; real secrets must never be in tree
*.pem
*.key
*.p12
# The AWS Nitro G1 root certificate is PUBLIC and intentionally
# in-tree — see docs/m3-decisions.md D51. Carve it out of *.pem.
!crates/qfc-enclave/data/aws-nitro-root-g1.pem
secrets/
.claude/
